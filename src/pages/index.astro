---
import Nav from "../components/Nav.astro";
import BaseLayout from "../layouts/BaseLayouts.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
---

<BaseLayout title="Blog | Myllena">
  <Nav />

  <section class="hero">
    <p class="label">anotações de dev</p>
    <h1>Aprendendo em público</h1>
    <p class="sub">Aqui eu documento o que estou aprendendo — Astro, CSS, TypeScript, e tudo mais que aparecer no caminho.</p>
  </section>

  <section class="posts">
    {posts.map((post: typeof posts[0]) => (
      <a href={`/blog/${post.id}`} class="post-card"> 
        <div class="post-top">
          <div class="tags-container">
            {post.data.tags && post.data.tags.map((tag: unknown) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          <span class="date">
            {post.data.date.toLocaleDateString("pt-BR", { day: "2-digit", month: "short", year: "numeric" })}
          </span>
        </div>
        <h2>{post.data.title}</h2>
        <p>{post.data.description}</p>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .hero {
    margin-bottom: 48px;
  }

  .label {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 10px;
  }

  h1 {
    font-size: clamp(24px, 5vw, 28px);
    font-weight: 500;
    letter-spacing: -0.5px;
    margin-bottom: 10px;
    line-height: 1.2;
  }

  .sub {
    font-size: 15px;
    color: var(--color-muted);
    max-width: 480px;
    line-height: 1.5;
  }

  .posts {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .post-card {
    display: block;
    padding: 20px 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s;
  }

  .post-card:hover {
    opacity: 0.6;
  }

  .post-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
    flex-wrap: wrap; 
  }
  
  .tags-container {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 11px;
    background: var(--color-tag-bg);
    color: var(--color-muted);
    padding: 4px 8px;
    border-radius: 4px;
    white-space: nowrap;
  }

  .date {
    font-size: 12px;
    color: var(--color-muted);
  }

  h2 {
    font-size: clamp(16px, 4vw, 17px);
    font-weight: 500;
    letter-spacing: -0.3px;
    margin-bottom: 6px;
    line-height: 1.3;
  }

  p {
    font-size: 14px;
    color: var(--color-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2; 
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 600px) {
    .hero {
      margin-bottom: 32px;
    }
    .post-card {
      padding: 16px 0;
    }
  }
</style>